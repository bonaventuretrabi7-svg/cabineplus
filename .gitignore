# Dépendances
node_modules/

# Web assets générés pour Capacitor (voir scripts/build-www.js)
www/

# Paquets de déploiement web générés (voir scripts/build-dist.js /
# build-dist-client.js) — régénérables via npm run build:dist
dist/
dist-client/
*.zip

# Android — artefacts de build, ne pas versionner
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/keystore.properties
*.keystore
*.jks

# APK compilés localement (le seul publié est downloads/kbineplus.apk, à
# copier manuellement après compilation — voir BUILD_APK.md)
*.apk
!downloads/kbineplus.apk

# Sauvegardes d'éditeur, logs d'installation locaux
*.bak
*.log

# État/outils locaux de Claude Code — pas partie du projet
.claude/

# Identifiants MySQL réels (voir api/config.example.php) — jamais commités,
# créé directement sur l'hébergement (Hostinger File Manager). En local, ce
# même fichier pointe plutôt vers la base de test MariaDB (voir
# tests-php/README.md) — jamais les vraies infos de prod.
api/config.php

# Clé de compte de service Firebase (notifications push, voir
# api/config.example.php / api/push_common.php) — jamais commitée, donne
# accès à l'envoi de notifications pour tout le projet Firebase. Déposée
# directement sur l'hébergement (Hostinger File Manager), comme config.php.
api/firebase-service-account.json

# Suite de tests PHP (tests-php/, voir composer.json) — dépendances
# Composer et cache PHPUnit, jamais commités (comme node_modules/).
vendor/
.phpunit.cache/
